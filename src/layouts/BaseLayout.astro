---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Product design portfolio' } = Astro.props;
const siteName = 'Karolina';
const fullTitle = title === 'Home' ? `${siteName} — Product design` : `${title} · ${siteName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen bg-stone-50 text-base text-stone-800 font-sans antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      import '../scripts/scroll-motion';
    </script>
  </body>
</html>
