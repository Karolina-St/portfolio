---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter((p) => p.data.listOnWorkPage)
  .sort((a, b) => a.data.order - b.data.order);

const failureStories = (await getCollection('failureStories')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout title="Work" description="Case studies and project work — product design portfolio.">
  <div class="mx-auto max-w-content px-4 py-16 md:px-6 md:py-24">
    <header class="max-w-prose mb-16 md:mb-20" data-reveal>
      <h1 class="font-serif text-3xl md:text-4xl text-stone-900 leading-tight">Work</h1>
    </header>

    <ul class="space-y-16 md:space-y-20" data-reveal-stagger>
      {
        projects.map((project) => (
          <li>
            <article class="max-w-prose border-b border-stone-200 pb-16 md:pb-20 last:border-0">
              {project.data.thumbnail ? (
                <div class="mb-5 aspect-video w-full overflow-hidden rounded-lg">
                  <Image
                    src={project.data.thumbnail}
                    alt=""
                    class="h-full w-full object-cover"
                    loading="lazy"
                    decoding="async"
                    quality={95}
                    widths={[672, 1008, 1344, 1600]}
                    sizes="(min-width: 768px) 42rem, 100vw"
                  />
                </div>
              ) : (
                <div
                  class="mb-5 flex aspect-video w-full items-center justify-center rounded-lg border border-dashed border-stone-300 bg-stone-50 text-sm text-stone-500"
                  aria-hidden="true"
                >
                  Project image
                </div>
              )}
              <h2 class="font-serif text-2xl text-stone-900">
                {project.data.caseStudyComingSoon ? (
                  <span>{project.data.title}</span>
                ) : (
                  <a
                    href={`/work/${project.slug}`}
                    class="hover:opacity-80 transition-opacity"
                  >
                    {project.data.title}
                  </a>
                )}
              </h2>
              {project.data.role && (
                <p class="mt-2 text-xs font-medium uppercase tracking-wider text-stone-500">
                  {project.data.role}
                </p>
              )}
              <p class="mt-4 text-stone-700 leading-relaxed">{project.data.description}</p>
              <p class="mt-6">
                {project.data.caseStudyComingSoon ? (
                  <span class="text-base text-stone-500">Coming soon</span>
                ) : (
                  <a
                    href={`/work/${project.slug}`}
                    class="text-base font-medium text-stone-900 underline underline-offset-4 decoration-stone-300 hover:decoration-stone-600 transition-colors"
                  >
                    Read case study
                  </a>
                )}
              </p>
            </article>
          </li>
        ))
      }
    </ul>

    <section
      class="mt-16 md:mt-24 border-t border-stone-200 pt-16 md:pt-20"
      aria-labelledby="failure-stories-heading"
    >
      <h2
        id="failure-stories-heading"
        class="font-serif text-2xl md:text-3xl text-stone-900"
        data-reveal
      >
        Failure stories
      </h2>
      <ul class="mt-10 md:mt-12 space-y-16 md:space-y-20" data-reveal-stagger>
        {
          failureStories.map((story) => (
            <li>
              <article class="max-w-prose border-b border-stone-200 pb-16 md:pb-20 last:border-0">
                <div
                  class="mb-5 flex aspect-video w-full items-center justify-center rounded-lg border border-dashed border-stone-300 bg-stone-50 text-sm text-stone-500"
                  aria-hidden="true"
                >
                  Project image
                </div>
                <h3 class="font-serif text-2xl text-stone-900">
                  {story.data.caseStudyComingSoon ? (
                    <span>{story.data.title}</span>
                  ) : (
                    <a
                      href={`/work/failure/${story.slug}`}
                      class="hover:opacity-80 transition-opacity"
                    >
                      {story.data.title}
                    </a>
                  )}
                </h3>
                {story.data.role && (
                  <p class="mt-2 text-xs font-medium uppercase tracking-wider text-stone-500">
                    {story.data.role}
                  </p>
                )}
                <p class="mt-4 text-stone-700 leading-relaxed">{story.data.description}</p>
                <p class="mt-6">
                  {story.data.caseStudyComingSoon ? (
                    <span class="text-base text-stone-500">Coming soon</span>
                  ) : (
                    <a
                      href={`/work/failure/${story.slug}`}
                      class="text-base font-medium text-stone-900 underline underline-offset-4 decoration-stone-300 hover:decoration-stone-600 transition-colors"
                    >
                      Read case study
                    </a>
                  )}
                </p>
              </article>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>
