---
import BaseLayout from '../layouts/BaseLayout.astro';

const figmaPairImgClass =
  'block h-auto w-full origin-center rounded-lg transition-transform duration-300 ease-out will-change-transform group-hover:scale-105 motion-reduce:transition-none motion-reduce:group-hover:scale-100';

const figmaExamples = [
  { caption: 'Graphic challenge: Kodak Ultra F9 | Figma' },
  {
    caption: 'Graphic challenge: Vinyl Turntable | Figma',
    leftSrc: '/Fun/vinyl.png',
    leftWidth: 2846,
    leftHeight: 1908,
    leftAlt: 'Vinyl turntable illustration',
    rightSrc: '/Fun/vinyl-outline.png',
    rightWidth: 2846,
    rightHeight: 1908,
    rightAlt: 'Vinyl turntable outline illustration',
  },
  {
    caption: 'Graphic challenge: Alarm Clock | Figma',
    leftSrc: '/Fun/alarm-clock.png',
    leftWidth: 3004,
    leftHeight: 2014,
    leftAlt: 'Alarm clock illustration',
    rightSrc: '/Fun/alarm-clock-outline.png',
    rightWidth: 3004,
    rightHeight: 2014,
    rightAlt: 'Alarm clock outline illustration',
  },
  {
    caption: 'Graphic challenge: Xbox pad | Figma',
    leftSrc: '/Fun/pad.png',
    leftWidth: 3200,
    leftHeight: 2200,
    leftAlt: 'Game controller illustration',
    rightSrc: '/Fun/pad-outline.png',
    rightWidth: 3200,
    rightHeight: 2200,
    rightAlt: 'Game controller outline illustration',
  },
];
---

<BaseLayout
  title="Fun"
  description="Side projects, experiments, and things that don’t fit a case study."
>
  <article class="mx-auto max-w-content px-6 py-16 md:py-24">
    <header class="max-w-prose">
      <h1 class="font-serif text-3xl md:text-4xl text-stone-900 leading-tight">Fun</h1>
      <p class="mt-6 text-base leading-relaxed text-stone-700">
        Space for things made for fun and exercise
      </p>
    </header>
    <section class="mt-14 md:mt-16" aria-labelledby="fun-figma-heading">
      <h2 id="fun-figma-heading" class="font-serif text-2xl md:text-3xl text-stone-900">
        Figma exploration
      </h2>
      <p class="mt-4 max-w-prose text-base leading-relaxed text-stone-700">
        UI elements and graphic challenges, done without a specific context.
      </p>
      <div class="mt-10 flex flex-col gap-24 md:gap-32 lg:gap-40">
        {
          figmaExamples.map((example, index) => (
            <section
              class="min-w-0"
              aria-label={`Figma example ${index + 1} of ${figmaExamples.length}`}
            >
              <div
                class="-mx-2 flex flex-col gap-8 px-2 md:-mx-3 md:flex-row md:gap-10 md:px-3 md:items-stretch"
              >
                <figure class="group m-0 min-w-0 flex-1 overflow-visible">
                  <img
                    src={example.leftSrc ?? '/camera.png'}
                    alt={`${example.leftAlt ?? 'Camera illustration'} — Figma exploration (${index + 1} of ${figmaExamples.length})`}
                    width={example.leftWidth ?? 1542}
                    height={example.leftHeight ?? 919}
                    class={figmaPairImgClass}
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
                <figure class="group m-0 min-w-0 flex-1 overflow-visible">
                  <img
                    src={example.rightSrc ?? '/camera-outline.png'}
                    alt={`${example.rightAlt ?? 'Camera outline illustration'} — Figma exploration (${index + 1} of ${figmaExamples.length})`}
                    width={example.rightWidth ?? 1448}
                    height={example.rightHeight ?? 835}
                    class={figmaPairImgClass}
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
              </div>
              <p class="mt-6 px-2 text-sm text-stone-600 md:px-3">{example.caption}</p>
            </section>
          ))
        }
      </div>
    </section>
  </article>
</BaseLayout>
