---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Fun"
  description="Side projects, experiments, and things that don’t fit a case study."
>
  <article class="mx-auto max-w-content px-6 py-16 md:py-24">
    <header class="max-w-prose">
      <h1 class="font-serif text-3xl md:text-4xl text-stone-900 leading-tight">Fun</h1>
      <p class="mt-6 text-lg leading-relaxed text-stone-700">
        Space for sketching, typography exploration, and ideas that never needed a sprint. Swap this copy for
        links to side projects, talks, or visual experiments when you are ready.
      </p>
    </header>
    <ul class="mt-14 max-w-prose space-y-6 text-stone-700">
      <li>
        <span class="font-medium text-stone-900">Type & layout studies</span>
        — occasional posters and editorial layouts; mostly for practice.
      </li>
      <li>
        <span class="font-medium text-stone-900">Small tools</span>
        — scripts and one-off helpers for personal workflows.
      </li>
      <li>
        <span class="font-medium text-stone-900">Photography</span>
        — mostly documentary-style, nothing staged.
      </li>
    </ul>
  </article>
</BaseLayout>
