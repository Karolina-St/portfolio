---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const featuredProjects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const testimonials = (await getCollection('testimonials')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout
  title="Home"
  description="Product designer — calm, structured interfaces for fintech, health, and complex domains."
>
  <section
    class="mx-auto max-w-content px-4 md:px-6 pt-16 pb-20 md:pt-24 md:pb-28"
    data-reveal
  >
    <p class="font-serif text-3xl md:text-4xl lg:text-[2.5rem] leading-snug text-stone-900 max-w-prose">
      Hello!
    </p>
    <p class="mt-4 font-serif text-3xl md:text-4xl lg:text-[2.25rem] leading-[130%] lg:leading-[1.33] text-stone-900 max-w-prose">
      I like to understand how things work – and use that to design products that are clear, structured, and
      grounded in real user needs.
    </p>
    <h2 class="mt-8 max-w-prose text-base font-normal font-sans leading-relaxed text-stone-700">
      I often initiate new projects and approaches, including AI-related ones.
      Currently, I work at Plus (telco), and I’m also developing my own ideas through Saha Apps.
    </h2>
    <p class="mt-10">
      <a
        href="/about"
        class="text-base font-medium text-stone-900 underline underline-offset-4 decoration-stone-400 hover:decoration-stone-700 transition-colors"
      >
        More about me
      </a>
    </p>
  </section>

  <section class="border-t border-stone-200 bg-white overflow-hidden">
    <div
      class="mx-auto max-w-content px-4 md:px-6 py-20 md:py-28"
      data-parallax="subtle"
    >
      <div
        class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between mb-14 md:mb-16"
        data-reveal
      >
        <h2 class="font-serif text-2xl md:text-3xl text-stone-900">Selected work</h2>
      </div>
      <ul class="grid gap-12 md:gap-16 md:grid-cols-2" data-reveal-stagger>
        {
          featuredProjects.slice(0, 2).map((project) => (
            <li>
              <article>
                {project.data.thumbnail ? (
                  project.data.caseStudyComingSoon ? (
                    <div class="mb-4 w-full overflow-hidden rounded-lg">
                      <Image
                        src={project.data.thumbnail}
                        alt=""
                        class="h-auto w-full"
                        loading="lazy"
                        decoding="async"
                        quality={95}
                        widths={[672, 1008, 1344, 1600]}
                        sizes="(min-width: 768px) 50vw, 100vw"
                      />
                    </div>
                  ) : (
                    <a
                      href={`/work/${project.slug}`}
                      class="mb-4 block w-full overflow-hidden rounded-lg hover:opacity-80 transition-opacity focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-stone-900"
                      aria-label={`View project: ${project.data.title}`}
                    >
                      <Image
                        src={project.data.thumbnail}
                        alt=""
                        class="h-auto w-full"
                        loading="lazy"
                        decoding="async"
                        quality={95}
                        widths={[672, 1008, 1344, 1600]}
                        sizes="(min-width: 768px) 50vw, 100vw"
                      />
                    </a>
                  )
                ) : project.data.caseStudyComingSoon ? (
                  <div
                    class="mb-4 flex aspect-video w-full items-center justify-center rounded-lg border border-dashed border-stone-300 bg-stone-50 text-sm text-stone-500"
                    aria-hidden="true"
                  >
                    Project image
                  </div>
                ) : (
                  <a
                    href={`/work/${project.slug}`}
                    class="mb-4 block w-full rounded-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-stone-900"
                    aria-label={`View project: ${project.data.title}`}
                  >
                    <div
                      class="flex aspect-video w-full items-center justify-center rounded-lg border border-dashed border-stone-300 bg-stone-50 text-sm text-stone-500 hover:border-stone-400 transition-colors"
                      aria-hidden="true"
                    >
                      Project image
                    </div>
                  </a>
                )}
                <h3 class="font-serif text-xl text-stone-900">
                  {project.data.caseStudyComingSoon ? (
                    <span>{project.data.title}</span>
                  ) : (
                    <a
                      href={`/work/${project.slug}`}
                      class="hover:opacity-80 transition-opacity"
                    >
                      {project.data.title}
                    </a>
                  )}
                </h3>
                {project.data.role && (
                  <p class="mt-2 text-xs font-medium uppercase tracking-wider text-stone-500">
                    {project.data.role}
                  </p>
                )}
                <p class="mt-4 text-base leading-relaxed text-stone-700">{project.data.description}</p>
                <p class="mt-4">
                  {project.data.caseStudyComingSoon ? (
                    <span class="text-base text-stone-500">Coming soon</span>
                  ) : (
                    <a
                      href={`/work/${project.slug}`}
                      class="text-base font-medium text-stone-900 underline underline-offset-4 decoration-stone-300 hover:decoration-stone-600 transition-colors"
                    >
                      View project
                    </a>
                  )}
                </p>
              </article>
            </li>
          ))
        }
      </ul>
      <p class="mt-16 md:mt-20" data-reveal>
        <a
          href="/work"
          class="text-base font-medium text-stone-900 underline underline-offset-4 decoration-stone-400 hover:decoration-stone-700 transition-colors"
        >
          Show more
        </a>
      </p>
    </div>
  </section>

  <section class="border-t border-stone-200">
    <div class="mx-auto max-w-content px-4 md:px-6 py-20 md:py-28">
      <h2
        class="font-serif text-2xl md:text-3xl text-stone-900 mb-14 md:mb-16"
        data-reveal
      >
        What colleagues say
      </h2>
      <ul class="grid gap-12 md:gap-14 md:grid-cols-3" data-reveal-stagger>
        {
          testimonials.map((t) => (
            <li>
              <blockquote class="space-y-6">
                <p class="font-serif text-base leading-relaxed text-stone-800">
                  “{t.data.quote}”
                </p>
                <footer class="text-base text-stone-600">
                  <cite class="not-italic font-medium text-stone-800">{t.data.author}</cite>
                  <span class="block mt-1">
                    {t.data.role}
                    {t.data.company && ` · ${t.data.company}`}
                  </span>
                </footer>
              </blockquote>
            </li>
          ))
        }
      </ul>
      <p class="mt-16 md:mt-20" data-reveal>
        <a
          href="https://www.linkedin.com/in/karolina-stachowiak/details/recommendations/?detailScreenTabIndex=0"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-1.5 text-base font-medium text-stone-900 transition-colors"
        >
          <span class="underline underline-offset-4 decoration-stone-400 group-hover:decoration-stone-700">
            Show more on Linkedin
          </span>
          <span aria-hidden="true">→</span>
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
