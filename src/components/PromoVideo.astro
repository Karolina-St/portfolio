---
interface Props {
  /** Site-root path (e.g. `/videos/file.mp4`) or full URL — not a Vite `?url` import. */
  src?: string;
  /** Visible caption and primary accessible name for the video. */
  description: string;
  /**
   * Optional extra source: e.g. pass MP4 here when `src` is a `.mov` so Chrome can play the first listed format.
   */
  mp4Src?: string;
  /** Optional iframe embed URL, e.g. a YouTube embed URL. */
  iframeSrc?: string;
}

const { src, description, mp4Src, iframeSrc } = Astro.props;

function withBase(path: string): string {
  if (/^https?:\/\//i.test(path)) return path;
  if (!path.startsWith('/')) return path;
  const base = import.meta.env.BASE_URL;
  if (!base || base === '/') return path;
  return `${base.replace(/\/$/, '')}${path}`;
}

function mimeFromPath(path: string): string {
  const file = path.split('?')[0].split('#')[0].toLowerCase();
  if (file.endsWith('.mp4') || file.endsWith('.m4v')) return 'video/mp4';
  if (file.endsWith('.webm')) return 'video/webm';
  if (file.endsWith('.mov')) return 'video/quicktime';
  return 'video/mp4';
}

const primarySrc = src ? withBase(src) : undefined;
const extraMp4Src = mp4Src ? withBase(mp4Src) : undefined;
const primaryMime = src ? mimeFromPath(src) : 'video/mp4';
const downloadLabel =
  primaryMime === 'video/quicktime' ? 'Download the promo video (MOV)' : 'Download the promo video (MP4)';
---

<div class="promo-video not-prose my-8" data-promo-video>
  <figure class="m-0">
    <div
      class="relative aspect-video w-full overflow-hidden rounded-lg bg-stone-950"
      role="group"
      aria-label={`${description}: ${iframeSrc ? 'embedded video' : 'video player'}`}
    >
      {
        iframeSrc ? (
          <iframe
            class="h-full w-full"
            src={iframeSrc}
            title={description}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          ></iframe>
        ) : (
          <>
            <video
              class="h-full w-full object-contain"
              preload="metadata"
              playsinline
              aria-label={description}
            >
              {
                extraMp4Src ? (
                  <>
                    <source src={extraMp4Src} type="video/mp4" />
                    <source src={primarySrc} type={primaryMime} />
                  </>
                ) : (
                  <source src={primarySrc} type={primaryMime} />
                )
              }
              <a
                href={primarySrc}
                class="text-sm text-stone-300 underline underline-offset-2 hover:text-white"
              >
                {downloadLabel}
              </a>
            </video>
            <div
              class="pointer-events-none absolute inset-0 bg-gradient-to-t from-stone-950/40 to-transparent"
              aria-hidden="true"
            ></div>
            <div
              class="absolute bottom-0 right-0 flex items-center gap-2 p-3 md:p-3.5"
              role="toolbar"
              aria-label={`${description}: playback controls`}
            >
              <button
                type="button"
                data-promo-toggle
                class="pointer-events-auto inline-flex h-10 w-10 items-center justify-center rounded-md bg-white/90 text-stone-900 shadow-sm backdrop-blur-sm transition-colors hover:bg-white/95 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-stone-900"
              >
                <span data-icon-play aria-hidden="true">
                  <svg
                    class="h-5 w-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M9 6.5v11l9-5.5-9-5.5Z"></path>
                  </svg>
                </span>
                <span data-icon-pause class="hidden" aria-hidden="true">
                  <svg
                    class="h-5 w-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                  >
                    <path d="M9 7v10"></path>
                    <path d="M15 7v10"></path>
                  </svg>
                </span>
              </button>
              <button
                type="button"
                data-promo-mute
                class="pointer-events-auto inline-flex h-10 w-10 items-center justify-center rounded-md bg-white/90 text-stone-900 shadow-sm backdrop-blur-sm transition-colors hover:bg-white/95 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-stone-900"
              >
                <span data-icon-sound-on aria-hidden="true">
                  <svg
                    class="h-5 w-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M11 5 6 9H4v6h2l5 4V5Z"></path>
                    <path d="M16 9a4 4 0 0 1 0 6"></path>
                    <path d="M18 7a7 7 0 0 1 0 10"></path>
                  </svg>
                </span>
                <span data-icon-sound-off class="hidden" aria-hidden="true">
                  <svg
                    class="h-5 w-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M11 5 6 9H4v6h2l5 4V5Z"></path>
                    <path d="m17 9 4 4"></path>
                    <path d="m21 9-4 4"></path>
                  </svg>
                </span>
              </button>
            </div>
          </>
        )
      }
    </div>
    {
      !iframeSrc && (
        <p class="mt-2 hidden text-sm text-amber-900" data-promo-error role="alert">
          Playback failed in this browser. Use the download link in the player or try another browser.
        </p>
      )
    }
    <figcaption class="mt-3 text-center text-sm text-stone-600">
      {description}
    </figcaption>
  </figure>
</div>

<script>
  function bindPromoVideos() {
    document.querySelectorAll('[data-promo-video]').forEach((root) => {
      if (!(root instanceof HTMLElement) || root.dataset.promoBound) return;
      root.dataset.promoBound = 'true';
      const video = root.querySelector('video');
      const toggleBtn = root.querySelector('[data-promo-toggle]');
      const muteBtn = root.querySelector('[data-promo-mute]');
      const playIcon = root.querySelector('[data-icon-play]');
      const pauseIcon = root.querySelector('[data-icon-pause]');
      const soundOnIcon = root.querySelector('[data-icon-sound-on]');
      const soundOffIcon = root.querySelector('[data-icon-sound-off]');
      if (
        !video ||
        !toggleBtn ||
        !muteBtn ||
        !playIcon ||
        !pauseIcon ||
        !soundOnIcon ||
        !soundOffIcon
      )
        return;

      const v = video;
      const tb = toggleBtn;
      const mb = muteBtn;
      const pi = playIcon;
      const pa = pauseIcon;
      const so = soundOnIcon;
      const sf = soundOffIcon;

      const desc = v.getAttribute('aria-label') ?? 'Video';

      function syncPlayPause() {
        const paused = v.paused;
        pi.classList.toggle('hidden', !paused);
        pa.classList.toggle('hidden', paused);
        tb.setAttribute('aria-label', paused ? `Play: ${desc}` : `Pause: ${desc}`);
      }

      function syncMute() {
        const muted = v.muted;
        so.classList.toggle('hidden', muted);
        sf.classList.toggle('hidden', !muted);
        mb.setAttribute('aria-label', muted ? `Unmute: ${desc}` : `Mute: ${desc}`);
      }

      syncPlayPause();
      syncMute();

      const errEl = root.querySelector('[data-promo-error]');
      function showPlaybackError() {
        errEl?.classList.remove('hidden');
      }

      v.addEventListener('error', showPlaybackError);

      tb.addEventListener('click', () => {
        if (v.paused) {
          void v.play().catch(() => {
            showPlaybackError();
          });
        } else {
          v.pause();
        }
      });

      mb.addEventListener('click', () => {
        v.muted = !v.muted;
      });

      v.addEventListener('play', syncPlayPause);
      v.addEventListener('pause', syncPlayPause);
      v.addEventListener('ended', syncPlayPause);
      v.addEventListener('volumechange', syncMute);
    });
  }

  bindPromoVideos();
  document.addEventListener('astro:page-load', bindPromoVideos);
</script>
