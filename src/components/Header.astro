---
import NavLink from './NavLink.astro';

const links = [
  { href: '/about', label: 'About' },
  { href: '/work', label: 'Work' },
  { href: '/fun', label: 'Fun' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="border-b border-stone-200/80 bg-stone-50/90 backdrop-blur-sm sticky top-0 z-50">
  <div class="mx-auto max-w-content px-6 py-5 md:flex md:items-center md:justify-between md:py-6">
    <div class="flex items-center justify-between gap-4">
      <a
        href="/"
        class="font-serif text-lg text-stone-900 tracking-tight hover:opacity-80 transition-opacity"
      >
        Karolina Stachowiak
      </a>
      <details class="group relative md:hidden">
        <summary
          class="list-none cursor-pointer text-base font-medium text-stone-700 [&::-webkit-details-marker]:hidden"
        >
          Menu
        </summary>
        <nav
          class="absolute right-0 top-full z-50 mt-2 min-w-[12rem] border border-stone-200 bg-stone-50 py-2 shadow-sm"
          aria-label="Mobile"
        >
          <ul class="flex flex-col gap-1 px-3">
            {
              links.map(({ href, label }) => (
                <li>
                  <NavLink href={href} class="block py-2 text-base">
                    {label}
                  </NavLink>
                </li>
              ))
            }
            <li class="border-t border-stone-200 pt-2 mt-1">
              <a
                href="/cv.pdf"
                download
                class="block py-2 text-base text-stone-600 hover:text-stone-900 transition-colors"
              >
                CV
              </a>
            </li>
          </ul>
        </nav>
      </details>
    </div>
    <nav class="hidden md:flex md:items-center md:gap-10" aria-label="Primary">
      <ul class="flex items-center gap-8">
        {
          links.map(({ href, label }) => (
            <li>
              <NavLink href={href} class="text-base font-medium">
                {label}
              </NavLink>
            </li>
          ))
        }
        <li>
          <a
            href="/cv.pdf"
            download
            class="text-base font-medium text-stone-600 hover:text-stone-900 transition-colors"
          >
            CV
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>
